<?xml version="1.0" encoding="utf-8"?>
<!--
  Surgery Robot URDF
  ==================
  Articulated 3-DOF surgical arm with STL meshes.
  Meshes live in  package://laproscopic_grasper/meshes/

  Kinematic chain (all revolute, stacked along Z):
    base_link  (fixed to world)
      └─ joint_1  (Z-axis, yaw / shoulder pan)
           └─ link1   (upper arm, 0.12 m)
                └─ joint2  (Y-axis, shoulder lift)
                     └─ link2  (forearm, 0.12 m)
                          └─ joint3  (Y-axis, wrist pitch)
                               └─ link3  (end-effector / trocar)
-->

<robot name="surgery">

  <!-- ═══════════════════════════════════════════════════════════
       MATERIALS
  ═══════════════════════════════════════════════════════════ -->
  <material name="silver_blue">
    <color rgba="0.792 0.820 0.933 1.0"/>
  </material>
  <material name="dark_metal">
    <color rgba="0.18 0.18 0.22 1.0"/>
  </material>
  <material name="tip_blue">
    <color rgba="0.05 0.35 0.85 1.0"/>
  </material>

  <!-- ═══════════════════════════════════════════════════════════
       WORLD + BASE
  ═══════════════════════════════════════════════════════════ -->
  <link name="world"/>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ── BASE LINK ──────────────────────────────────────────── -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <mass value="0.50"/>
      <inertia ixx="2.6042e-03" ixy="0" ixz="0"
               iyy="2.6042e-03" iyz="0"
               izz="2.3542e-03"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://laproscopic_grasper/meshes/base_link.STL"
              scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="dark_metal"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <box size="0.17 0.17 0.08"/>
      </geometry>
    </collision>
  </link>

  <!-- ═══════════════════════════════════════════════════════════
       JOINT 1 — SHOULDER PAN (revolute about Z)
       Rotates the whole arm in the horizontal plane.
  ═══════════════════════════════════════════════════════════ -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child  link="link1"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="1.5708" effort="30.0" velocity="1.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ── LINK 1 (upper arm) ─────────────────────────────────── -->
  <link name="link1">
    <inertial>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <mass value="0.25"/>
      <inertia ixx="3.1200e-04" ixy="0" ixz="0"
               iyy="3.1200e-04" iyz="0"
               izz="1.1250e-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://laproscopic_grasper/meshes/link1.STL"
              scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="silver_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.030" length="0.12"/>
      </geometry>
    </collision>
  </link>

  <!-- ═══════════════════════════════════════════════════════════
       JOINT 2 — SHOULDER LIFT (revolute about Y)
       Tilts the forearm up / down.
  ═══════════════════════════════════════════════════════════ -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child  link="link2"/>
    <origin xyz="0 0 0.12" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="30.0" velocity="1.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ── LINK 2 (forearm) ───────────────────────────────────── -->
  <link name="link2">
    <inertial>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <mass value="0.18"/>
      <inertia ixx="2.3040e-04" ixy="0" ixz="0"
               iyy="2.3040e-04" iyz="0"
               izz="4.3560e-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://laproscopic_grasper/meshes/link2.STL"
              scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="silver_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.022" length="0.12"/>
      </geometry>
    </collision>
  </link>

  <!-- ═══════════════════════════════════════════════════════════
       JOINT 3 — WRIST PITCH (revolute about Y)
       Pitches the end-effector / trocar.
  ═══════════════════════════════════════════════════════════ -->
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child  link="link3"/>
    <origin xyz="0 0 0.12" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="30.0" velocity="1.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ── LINK 3 (wrist / end-effector) ─────────────────────── -->
  <link name="link3">
    <inertial>
      <origin xyz="0 0 0.07" rpy="0 0 0"/>
      <mass value="0.10"/>
      <inertia ixx="1.0260e-04" ixy="0" ixz="0"
               iyy="1.0260e-04" iyz="0"
               izz="5.0000e-07"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://laproscopic_grasper/meshes/link3.STL"
              scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="tip_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.07" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.012" length="0.14"/>
      </geometry>
    </collision>
  </link>

  <!-- ═══════════════════════════════════════════════════════════
       ROS2 CONTROL — Jazzy + gz_ros2_control (Harmonic)
  ═══════════════════════════════════════════════════════════ -->
  <ros2_control name="surgery_ros2_control" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <joint name="joint_1">
      <command_interface name="position">
        <param name="min">-1.5708</param>
        <param name="max"> 1.5708</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <joint name="joint2">
      <command_interface name="position">
        <param name="min">-1.5708</param>
        <param name="max"> 1.5708</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <joint name="joint3">
      <command_interface name="position">
        <param name="min">-1.5708</param>
        <param name="max"> 1.5708</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>

  <!-- ═══════════════════════════════════════════════════════════
       GAZEBO — Harmonic (gz-sim 8) compatible
  ═══════════════════════════════════════════════════════════ -->
  <gazebo>
    <plugin filename="gz_ros2_control-system"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find laproscopic_grasper)/config/surgery_controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
    <surface>
      <friction><ode><mu>0.8</mu><mu2>0.8</mu2></ode></friction>
      <contact><ode><kp>1e6</kp><kd>100.0</kd></ode></contact>
    </surface>
  </gazebo>

  <gazebo reference="link1">
    <material>Gazebo/SkyBlue</material>
    <surface>
      <friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction>
      <contact><ode><kp>1e6</kp><kd>100.0</kd></ode></contact>
    </surface>
  </gazebo>

  <gazebo reference="link2">
    <material>Gazebo/SkyBlue</material>
    <surface>
      <friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction>
      <contact><ode><kp>1e6</kp><kd>100.0</kd></ode></contact>
    </surface>
  </gazebo>

  <gazebo reference="link3">
    <material>Gazebo/Blue</material>
    <surface>
      <friction><ode><mu>0.5</mu><mu2>0.5</mu2></ode></friction>
      <contact><ode><kp>1e6</kp><kd>100.0</kd></ode></contact>
    </surface>
  </gazebo>

</robot>
