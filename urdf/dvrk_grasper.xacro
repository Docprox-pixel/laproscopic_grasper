<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="PI" value="3.14159265358"/>

  <!-- ================================================================
       HIGH-FIDELITY TWO-FINGER LAPAROSCOPIC GRASPER (V9 - NEON VISIBILITY)
       ================================================================
       Neon Green markers to guarantee visibility in any lighting.
       High-mass/High-damping joints for Gazebo stability.
       ================================================================ -->

  <xacro:macro name="dvrk_grasper" params="parent *origin">

    <!-- ── Attachment ──────────────────────────────────────────────── -->
    <joint name="grasper_base_joint" type="fixed">
      <parent link="${parent}"/>
      <child  link="grasper_adapter_link"/>
      <xacro:insert_block name="origin"/>
    </joint>

    <link name="grasper_adapter_link">
      <visual>
        <origin xyz="0 0 0.012" rpy="0 0 0"/>
        <geometry><cylinder radius="0.018" length="0.024"/></geometry>
        <material name="adapter_gray"><color rgba="0.6 0.6 0.65 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0.012" rpy="0 0 0"/>
        <geometry><cylinder radius="0.018" length="0.024"/></geometry>
      </collision>
      <inertial>
        <mass value="0.2"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>

    <joint name="grasper_shaft_joint" type="fixed">
      <parent link="grasper_adapter_link"/>
      <child  link="grasper_shaft"/>
      <origin xyz="0 0 0.024" rpy="0 0 0"/>
    </joint>

    <link name="grasper_shaft">
      <visual>
        <origin xyz="0 0 0.125" rpy="0 0 0"/>
        <geometry><cylinder radius="0.005" length="0.25"/></geometry>
        <material name="steel"><color rgba="0.8 0.8 0.8 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0.125" rpy="0 0 0"/>
        <geometry><cylinder radius="0.005" length="0.25"/></geometry>
      </collision>
      <inertial>
        <mass value="0.5"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.001"/>
      </inertial>
    </link>

    <!-- ── Wrist Pitch ─────────────────────────────────────────────── -->
    <joint name="grasper_pitch_joint" type="revolute">
      <parent link="grasper_shaft"/>
      <child  link="tool_wrist_sca_link"/>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-1.5708" upper="1.5708" effort="200" velocity="1.0"/>
      <dynamics damping="5.0" friction="0.5"/>
    </joint>

    <link name="tool_wrist_sca_link">
      <visual>
        <origin rpy="${PI/2} ${PI} 0" xyz="0.0051 0.0032 0"/>
        <geometry><mesh filename="package://laproscopic_grasper/meshes/HighFidelity/tool_wrist_sca_link.stl" scale="1 1 1"/></geometry>
      </visual>
      <visual>
        <origin xyz="0 0 0.005" rpy="0 0 0"/>
        <geometry><sphere radius="0.008"/></geometry>
        <material name="marker_neon"><color rgba="0.0 1.0 0.0 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0.005" rpy="0 0 0"/>
        <geometry><sphere radius="0.01"/></geometry>
      </collision>
      <inertial>
        <mass value="0.2"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>

    <!-- ── Wrist Yaw ───────────────────────────────────────────────── -->
    <joint name="grasper_yaw_joint" type="revolute">
      <parent link="tool_wrist_sca_link"/>
      <child  link="tool_wrist_sca_shaft_link"/>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit lower="-1.3963" upper="1.3963" effort="200" velocity="1.0"/>
      <dynamics damping="5.0" friction="0.5"/>
    </joint>

    <link name="tool_wrist_sca_shaft_link">
      <visual>
        <origin rpy="0 0 0" xyz="0 -0.0002 -0.0025"/>
        <geometry><mesh filename="package://laproscopic_grasper/meshes/HighFidelity/tool_wrist_sca_shaft_link.stl" scale="1 1 1"/></geometry>
      </visual>
      <visual>
        <origin xyz="0 0 0.005" rpy="0 0 0"/>
        <geometry><sphere radius="0.007"/></geometry>
        <material name="marker_neon"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.005" rpy="0 0 0"/>
        <geometry><sphere radius="0.01"/></geometry>
      </collision>
      <inertial>
        <mass value="0.2"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>

    <!-- ── Two-Finger Jaws ─────────────────────────────────────────── -->
    <joint name="grasper_jaw_joint" type="revolute">
      <parent link="tool_wrist_sca_shaft_link"/>
      <child  link="jaw_left_link"/>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="0.0" upper="0.8" effort="300" velocity="1.5"/>
      <dynamics damping="10.0" friction="1.0"/>
    </joint>

    <link name="jaw_left_link">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry><mesh filename="package://laproscopic_grasper/meshes/HighFidelity/tool_wrist_sca_ee_link_1.stl"/></geometry>
      </visual>
      <visual>
        <origin xyz="0 0.005 0.03" rpy="0 0 0"/>
        <geometry><box size="0.012 0.004 0.06"/></geometry>
        <material name="jaw_neon"><color rgba="0.0 1.0 0.3 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0.005 0.03" rpy="0 0 0"/>
        <geometry><box size="0.012 0.004 0.06"/></geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0.03"/><mass value="0.5"/>
        <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
      </inertial>
    </link>

    <joint name="grasper_jaw_mimic_joint" type="revolute">
      <parent link="tool_wrist_sca_shaft_link"/>
      <child  link="jaw_right_link"/>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-0.8" upper="0.0" effort="300" velocity="1.5"/>
      <mimic joint="grasper_jaw_joint" multiplier="-1.0" offset="0.0"/>
      <dynamics damping="10.0" friction="1.0"/>
    </joint>

    <link name="jaw_right_link">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry><mesh filename="package://laproscopic_grasper/meshes/HighFidelity/tool_wrist_sca_ee_link_2.stl"/></geometry>
      </visual>
      <visual>
        <origin xyz="0 -0.005 0.03" rpy="0 0 0"/>
        <geometry><box size="0.012 0.004 0.06"/></geometry>
        <material name="jaw_neon"/>
      </visual>
      <collision>
        <origin xyz="0 -0.005 0.03" rpy="0 0 0"/>
        <geometry><box size="0.012 0.004 0.06"/></geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0.03"/><mass value="0.5"/>
        <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
      </inertial>
    </link>

    <gazebo reference="jaw_left_link">
      <mu1>2.0</mu1><mu2>2.0</mu2><kp>1000000.0</kp><kd>50.0</kd>
    </gazebo>
    <gazebo reference="jaw_right_link">
      <mu1>2.0</mu1><mu2>2.0</mu2><kp>1000000.0</kp><kd>50.0</kd>
    </gazebo>

  </xacro:macro>
</robot>
