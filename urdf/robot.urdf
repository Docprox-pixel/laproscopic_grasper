      <geometry>
        <cylinder length="0.04" radius="0.01"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.02"/>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>
  <joint name="grasper_jaw_mimic_joint" type="revolute">
    <parent link="tool_wrist_sca_shaft_link"/>
    <child link="jaw_right_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.01"/>
    <axis xyz="0 1 0"/>
    <limit effort="300" lower="-0.8" upper="0.0" velocity="1.5"/>
    <mimic joint="grasper_jaw_joint" multiplier="-1.0" offset="0.0"/>
    <dynamics damping="5.0" friction="0.5"/>
  </joint>
  <link name="jaw_right_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
