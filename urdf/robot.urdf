    </inertial>
  </link>
  <!-- ── Jaws (Two-Finger) ────────────────────────────────────────── -->
  <joint name="grasper_jaw_joint" type="revolute">
    <parent link="tool_wrist_sca_shaft_link"/>
    <child link="jaw_left_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.01"/>
    <axis xyz="0 1 0"/>
    <limit effort="300" lower="0.0" upper="0.8" velocity="1.5"/>
    <dynamics damping="5.0" friction="0.5"/>
  </joint>
  <link name="jaw_left_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://laproscopic_grasper/meshes/HighFidelity/tool_wrist_sca_ee_link_1.stl"/>
      </geometry>
    </visual>
    <visual>
      <origin rpy="0 0 0" xyz="0 0.002 0.02"/>
      <geometry>
        <box size="0.008 0.003 0.04"/>
      </geometry>
      <material name="jaw_steel">
