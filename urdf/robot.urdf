      <geometry>
        <cylinder length="0.04" radius="0.01"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.02"/>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>
  <gazebo reference="jaw_left_link">
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
    <kp>1000000.0</kp>
    <kd>50.0</kd>
  </gazebo>
  <gazebo reference="jaw_right_link">
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
    <kp>1000000.0</kp>
    <kd>50.0</kd>
  </gazebo>
  <!-- ================================================================== -->
  <!--  ROS2 CONTROL                                                      -->
  <!-- ================================================================== -->
  <ros2_control name="kuka_laproscopic_grasper_system" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <!-- ==== KUKA Arm joints ==== -->
    <joint name="iiwa14_joint1">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="iiwa14_joint2">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="iiwa14_joint3">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="iiwa14_joint4">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="iiwa14_joint5">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="iiwa14_joint6">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="iiwa14_joint7">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <!-- ==== Grasper joints (Merged) ==== -->
    <joint name="grasper_pitch_joint">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="grasper_yaw_joint">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="grasper_jaw_joint">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.8</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>
  <!-- ================================================================== -->
  <!--  GAZEBO PLUGINS                                                    -->
  <!-- ================================================================== -->
  <!-- The config_path shouldn't be overridden if the launch file passes it or launch injects plugin block -->
  <!-- We'll keep the template simple, launch file will inject its own plugin parameters if needed. -->
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters></parameters>
    </plugin>
  </gazebo>
  <!-- Force/Torque sensor on trocar shaft (mounted at shaft/wrist junction) -->
  <gazebo reference="grasper_pitch_joint">
    <sensor name="shaft_force_torque" type="force_torque">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <topic>shaft_force_torque</topic>
    </sensor>
  </gazebo>
  <!-- Contact sensors on jaw tips -->
  <!-- Contact sensors on jaw tips -->
  <gazebo reference="jaw_left_link">
    <sensor name="jaw_left_contact" type="contact">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <contact>
        <collision>jaw_left_link_collision</collision>
      </contact>
      <topic>jaw_left_contact</topic>
    </sensor>
  </gazebo>
  <gazebo reference="jaw_right_link">
    <sensor name="jaw_right_contact" type="contact">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <contact>
        <collision>jaw_right_link_collision</collision>
      </contact>
      <topic>jaw_right_contact</topic>
    </sensor>
  </gazebo>
</robot>
