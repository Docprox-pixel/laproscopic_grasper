      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <!-- ── Wrist Pitch ─────────────────────────────────────────────── -->
  <joint name="grasper_pitch_joint" type="revolute">
    <parent link="grasper_shaft"/>
    <child link="tool_wrist_sca_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.25"/>
    <axis xyz="0 1 0"/>
    <limit effort="200" lower="-1.5708" upper="1.5708" velocity="1.0"/>
    <dynamics damping="5.0" friction="0.5"/>
  </joint>
  <link name="tool_wrist_sca_link">
    <visual>
      <origin rpy="1.57079632679 3.14159265358 0" xyz="0.0051 0.0032 0"/>
      <geometry>
        <mesh filename="package://laproscopic_grasper/meshes/HighFidelity/tool_wrist_sca_link.stl" scale="1 1 1"/>
      </geometry>
    </visual>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.005"/>
      <geometry>
        <sphere radius="0.008"/>
      </geometry>
      <material name="joint_red">
        <color rgba="1 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.005"/>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <!-- ── Wrist Yaw ───────────────────────────────────────────────── -->
  <joint name="grasper_yaw_joint" type="revolute">
    <parent link="tool_wrist_sca_link"/>
    <child link="tool_wrist_sca_shaft_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.01"/>
    <axis xyz="1 0 0"/>
    <limit effort="200" lower="-1.3963" upper="1.3963" velocity="1.0"/>
    <dynamics damping="5.0" friction="0.5"/>
  </joint>
  <link name="tool_wrist_sca_shaft_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 -0.0002 -0.0025"/>
      <geometry>
        <mesh filename="package://laproscopic_grasper/meshes/HighFidelity/tool_wrist_sca_shaft_link.stl" scale="1 1 1"/>
      </geometry>
    </visual>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.005"/>
      <geometry>
        <sphere radius="0.007"/>
      </geometry>
